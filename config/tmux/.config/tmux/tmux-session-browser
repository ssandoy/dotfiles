#!/usr/bin/env bash
set -euo pipefail

SESSION_FORMAT="#{session_name}"

if [[ "${1-}" == "--popup" ]]; then
    popup_args=(-w 70% -h 30% -E)

    if [[ -n "${2-}" ]]; then
        popup_args=(-c "$2" "${popup_args[@]}")
    fi

    tmux popup "${popup_args[@]}" "$HOME/.config/tmux/tmux-session-browser"
    exit 0
fi

if ! sessions=$(tmux list-sessions -F "${SESSION_FORMAT}" 2>/dev/null); then
    exit 0
fi

if [[ -z "${sessions}" ]]; then
    exit 0
fi

selected=$(
    printf "%s\n" "${sessions}" | fzf \
        --prompt 'session > ' \
        --layout reverse \
        --border \
        --border-label ' Session Browser ' \
        --cycle \
        --bind 'tab:down,btab:up' \
        --exit-0
) || exit 0

if [[ -z "${selected}" ]]; then
    exit 0
fi

session_name="${selected}"

if [[ -n "${TMUX-}" ]]; then
    tmux switch-client -t "${session_name}"
else
    tmux attach -t "${session_name}"
fi
